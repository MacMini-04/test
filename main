from flask import Flask, request, jsonify
import base64
import subprocess
import tempfile
import os

app = Flask(__name__)

@app.route('/ocr', methods=['POST'])
def ocr():
    data = request.json
    pdf_b64 = data.get('pdf')

    if not pdf_b64:
        return jsonify({'error': 'No PDF provided'}), 400

    with tempfile.TemporaryDirectory() as tmpdir:
        pdf_path = os.path.join(tmpdir, 'mail.pdf')
        img_path = os.path.join(tmpdir, 'mail.jpg')
        txt_path = os.path.join(tmpdir, 'output')

        with open(pdf_path, 'wb') as f:
            f.write(base64.b64decode(pdf_b64))

        subprocess.run(['convert', '-density', '150', f'{pdf_path}[0]', img_path], check=True)
        subprocess.run(['tesseract', img_path, txt_path], check=True)

        with open(f'{txt_path}.txt', 'r') as f:
            text = f.read()

    return jsonify({'text': text})

if __name__ == '__main__':
    app.run(host='0.0.0.0', port=5000)
